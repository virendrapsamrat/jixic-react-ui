{
  "name": "react-ui-component-library",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.24.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build:ui && npm run build:native-ui && npm run build:docs && mkdir -p dist && cp -R apps/docs/out/. dist",
    "build:docs": "npm --workspace @repo/docs run build",
    "build:native-ui": "npm --workspace @jixic/react-native-ui run build",
    "build:ui": "npm --workspace @jixic/react-ui run build",
    "changeset": "changeset",
    "clean": "turbo clean && rm -rf node_modules",
    "dev": "turbo dev --parallel",
    "docs": "npm --workspace @repo/docs run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "turbo lint",
    "publish:native-ui": "npm --workspace @jixic/react-native-ui publish --access public",
    "publish:ui": "npm --workspace @jixic/react-ui publish --access public",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.12",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
