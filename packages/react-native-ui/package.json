{
  "name": "@jixic/react-native-ui",
  "version": "0.1.1",
  "description": "Accessible React Native and Expo UI primitives with TypeScript types and shared design tokens.",
  "license": "MIT",
  "homepage": "https://github.com/virendrapsamrat/-jixic-react-ui#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/virendrapsamrat/-jixic-react-ui.git",
    "directory": "packages/react-native-ui"
  },
  "bugs": {
    "url": "https://github.com/virendrapsamrat/-jixic-react-ui/issues"
  },
  "keywords": [
    "react-native",
    "expo",
    "react-native-ui",
    "expo-ui",
    "ui-library",
    "components",
    "component-library",
    "design-system",
    "typescript",
    "mobile-ui",
    "ios",
    "android"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./dist/index.js",
  "exports": {
    ".": {
      "react-native": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "react": ">=18.2.0 || >=19.0.0",
    "react-native": ">=0.73.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/react": "^18.2.79",
    "react": "^18.2.0",
    "react-native": "^0.76.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
